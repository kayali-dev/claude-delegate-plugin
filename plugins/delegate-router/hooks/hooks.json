{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/delegate-bootstrap\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "(^|_)delegate_codex__codex(-reply)?$|(^|_)delegate_control__delegate_(start|resume)$|^Skill$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/delegate-quota-hook\"",
            "timeout": 5,
            "statusMessage": "Checking delegation allowance"
          }
        ]
      }
    ]
  }
}
