{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/delegate-bootstrap\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__delegate_codex__codex|mcp__delegate_codex__codex-reply|mcp__delegate_control__delegate_start|mcp__delegate_control__delegate_resume|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/delegate-quota-hook\"",
            "timeout": 5,
            "statusMessage": "Checking delegation allowance"
          }
        ]
      }
    ]
  }
}
