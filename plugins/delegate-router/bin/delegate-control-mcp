      }, description: 'Write modes only. Run this coordinator-owned /bin/sh command in the job cwd after provider completion.' },
      allowedPaths: { type: 'array', items: { type: 'string' }, description: 'Repo-relative path prefixes (or * globs) this job may create/modify. Enforced post-hoc: out-of-scope changed files are recorded as scopeViolations on the job and emitted as a scope.violation event; the fence is also injected into the worker prompt.' },
      waitFor: { enum: ['session', 'turn', 'first-output'], description: 'Bounded wait for provider session establishment, the first turn, or the first visible output event.' },
      waitForSession: { type: 'boolean', description: 'Block (up to ~30s) until the provider session id is recorded before returning, so a plan can be filed under the delegate session id with no race.' },
      dryRun: { type: 'boolean', description: 'Return the fully resolved launch and exact provider packet without creating a job, staging files, or spawning a provider.' },
      sandbox: { enum: ['auto', 'off'], description: 'off disables provider sandboxing (Codex danger-full-access, Cursor --sandbox disabled) so the worker can use git, host CLIs, and live web search/fetch. Judge necessity from the task; if unsure whether the sandbox can stay on, ask the user before setting off.' },
      allowSensitive: { type: 'boolean' }, overrideLimit: { type: 'boolean' }, overrideWriter: { type: 'boolean' },
