      transport: { enum: ['app-server', 'acp', 'headless'] }
    } }
  },
  { name: 'delegate_inspect', description: 'Inspect a supervised or legacy job snapshot and its current revision. Orphaned jobs whose worker died are reconciled to failed.', inputSchema: { type: 'object', required: ['jobId'], properties: { jobId: { type: 'string' }, resultWindow: { type: 'object', additionalProperties: false, properties: { find: { type: 'string', minLength: 1 }, offset: { type: 'integer', minimum: 0 }, maxChars: { type: 'integer', minimum: 1000, maximum: 200000 } } } } } },
  { name: 'delegate_list', description: 'List recent delegation jobs, optionally filtered or summarized by fan-out group.', inputSchema: { type: 'object', properties: { limit: { type: 'integer', minimum: 1, maximum: 100 }, activeOnly: { type: 'boolean' }, status: { type: 'array', items: { enum: ['queued', 'running', 'completed', 'failed', 'cancelled'] } }, groupId: { type: 'string' }, groupSummary: { type: 'boolean' } } } },
  { name: 'delegate_stats', description: 'Return read-only aggregate delegation outcomes and token totals from the terminal audit log.', inputSchema: { type: 'object', additionalProperties: false, properties: { since: { type: 'string', description: "Optional duration such as '24h' or '7d'." } } } },
  { name: 'delegate_events', description: 'Read normalized live events using a monotonic sequence cursor, with optional bounded long polling.', inputSchema: { type: 'object', required: ['jobId'], properties: { jobId: { type: 'string' }, afterSeq: { type: 'integer' }, limit: { type: 'integer', minimum: 1, maximum: 1000 }, waitMs: { type: 'integer', minimum: 0, maximum: 30000 }, types: { type: 'array', items: { type: 'string' } } } } },
  { name: 'delegate_transcript', description: 'Read user-visible messages, plans, tool activity, and errors, paginated by sequence cursor. Streaming deltas and raw tool output are omitted unless verbose is set. Hidden reasoning is never returned.', inputSchema: { type: 'object', required: ['jobId'], properties: { jobId: { type: 'string' }, afterSeq: { type: 'integer' }, limit: { type: 'integer', minimum: 1, maximum: 1000 }, verbose: { type: 'boolean' } } } },
  { name: 'delegate_diff', description: 'Return the latest recorded unified diff (windowed by offset/maxChars for large diffs), a per-file stat summary with statOnly, or a per-file filtered view with paths (e.g. the job allowedPaths).', inputSchema: { type: 'object', required: ['jobId'], properties: { jobId: { type: 'string' }, statOnly: { type: 'boolean' }, offset: { type: 'integer', minimum: 0 }, maxChars: { type: 'integer', minimum: 1000, maximum: 200000 }, paths: { type: 'array', items: { type: 'string' } } } } },
  { name: 'delegate_files', description: 'Return files reported as changed by the provider.', inputSchema: jobOnly() },
  { name: 'delegate_steer', description: 'Correct an active job. Codex can steer the same turn; Cursor explicitly cancels and resumes.', inputSchema: { type: 'object', required: ['jobId', 'expectedRevision', 'text'], properties: { jobId: { type: 'string' }, expectedRevision: { type: 'integer' }, expectedTurnId: { type: 'string' }, correctionId: { type: 'string' }, strategy: { enum: ['auto', 'same-turn', 'restart', 'next-turn'] }, text: { type: 'string' } } } },
  { name: 'delegate_cancel', description: 'Request provider-aware cancellation using optimistic revision control.', inputSchema: { type: 'object', required: ['jobId', 'expectedRevision'], properties: { jobId: { type: 'string' }, expectedRevision: { type: 'integer' }, commandId: { type: 'string' } } } },
  { name: 'delegate_release', description: 'Release a startPaused job to send its first prompt, using optimistic revision control.', inputSchema: { type: 'object', required: ['jobId', 'expectedRevision'], properties: { jobId: { type: 'string' }, expectedRevision: { type: 'integer' }, commandId: { type: 'string' } } } },
  { name: 'delegate_respond', description: 'Answer a pending Cursor question or accept/reject a proposed plan using optimistic revision control. Retry with the same commandId for idempotency.', inputSchema: { type: 'object', required: ['jobId', 'expectedRevision'], properties: { jobId: { type: 'string' }, expectedRevision: { type: 'integer' }, requestId: { type: 'string' }, answer: { type: 'string' }, accept: { type: 'boolean' }, response: { type: 'object' }, commandId: { type: 'string' } } } },
  { name: 'delegate_resume', description: 'Start a new supervised job on the same provider session or thread.', inputSchema: { type: 'object', required: ['jobId', 'prompt'], properties: { jobId: { type: 'string' }, prompt: { type: 'string' }, model: { type: 'string' }, mode: { type: 'string' }, cwd: { type: 'string' }, effort: { type: 'string' }, timeoutSeconds: { type: 'integer', minimum: 60, maximum: 86400 }, maxOutputTokens: { type: 'integer', minimum: 1 }, retryPolicy: { type: 'object', required: ['maxAttempts', 'retryOn'], additionalProperties: false, properties: { maxAttempts: { type: 'integer', minimum: 1, maximum: 5 }, retryOn: { type: 'array', uniqueItems: true, items: { enum: ['transport', 'rate-limit'] } } } }, verify: { type: 'object', required: ['command'], additionalProperties: false, properties: { command: { type: 'string', minLength: 1 }, timeoutSeconds: { type: 'integer', minimum: 1, maximum: 86400, default: 600 } } }, network: { type: 'boolean' }, networkAllow: { type: 'array', items: { type: 'string' } }, addDirs: { type: 'array', items: { type: 'string' } }, approveMcps: { type: 'boolean' }, cursorWorktree: { type: 'boolean' }, cursorWorktreeBase: { type: 'string' }, sandbox: { enum: ['auto', 'off'] }, allowedPaths: { type: 'array', items: { type: 'string' } }, allowSensitive: { type: 'boolean' }, overrideLimit: { type: 'boolean' }, overrideWriter: { type: 'boolean' } } } },
  { name: 'delegate_review_round', description: 'Resume a terminal job with findings plus its recorded diff stat, changed files, and allowed scope.', inputSchema: { type: 'object', required: ['jobId', 'prompt'], properties: { jobId: { type: 'string' }, prompt: { type: 'string', minLength: 1 } } } },
  { name: 'delegate_usage', description: 'Return per-job observed usage, chain-cumulative token totals, and provider allowance headroom.', inputSchema: jobOnly() }
];

function jobOnly() {
  return { type: 'object', required: ['jobId'], properties: { jobId: { type: 'string' } } };
}

async function dispatch(name, args) {
  if (name === 'delegate_start') {
    const job = launchManagedJob(args);
    if (job.dryRun) return job;
    const target = args.waitFor ?? (args.waitForSession === true ? 'session' : null);
    return target ? waitForJob(job.id, target) : job;
  }
  if (name === 'delegate_inspect') {
    const job = inspectJob(args.jobId);
    return args.resultWindow ? { ...job, ...sliceResultText(job.resultText, args.resultWindow) } : job;
  }
  if (name === 'delegate_events') {
    const deadline = Date.now() + Math.min(Math.max(Number(args.waitMs || 0), 0), 30000);
    let page = readJobEventPage(args.jobId, args);
    while (!page.events.length && Date.now() < deadline) {
      await new Promise((resolve) => setTimeout(resolve, Math.min(200, deadline - Date.now())));
      page = readJobEventPage(args.jobId, { ...args, afterSeq: page.nextSeq });
    }
    return capEventsBySize(page);
  }
  if (name === 'delegate_list') return args.groupSummary ? groupSummary(args.groupId) : listManagedJobs(args);
  if (name === 'delegate_stats') {
    const unknown = Object.keys(args).filter((key) => key !== 'since');
    if (unknown.length) throw brokerError('INVALID_REQUEST', `delegate_stats unknown parameter${unknown.length === 1 ? '' : 's'}: ${unknown.join(', ')}`);
    return aggregateAudit(readAuditLog(), { since: args.since });
  }
  if (name === 'delegate_transcript') return jobTranscriptPage(args.jobId, args);
  if (name === 'delegate_diff') {
    const attributionConfidence = inspectJob(args.jobId).attributionConfidence;
    const diff = filterDiffPaths(jobDiff(args.jobId), args.paths);
    if (args.statOnly) return { ...diffStat(diff), attributionConfidence };
    return { ...sliceDiff(diff, args), attributionConfidence };
  }
  if (name === 'delegate_files') return { files: jobFiles(args.jobId), attributionConfidence: inspectJob(args.jobId).attributionConfidence };
  if (name === 'delegate_steer') return submitControl(args.jobId, { type: 'steer', correctionId: args.correctionId, strategy: args.strategy || 'auto', text: args.text, expectedTurnId: args.expectedTurnId }, args.expectedRevision);
  if (name === 'delegate_cancel') return submitControl(args.jobId, { type: 'cancel', commandId: args.commandId }, args.expectedRevision);
  if (name === 'delegate_release') return submitControl(args.jobId, { type: 'release', commandId: args.commandId }, args.expectedRevision);
  if (name === 'delegate_respond') return submitControl(args.jobId, { type: 'respond', requestId: args.requestId, answer: args.answer, accept: args.accept, response: args.response, commandId: args.commandId }, args.expectedRevision);
  if (name === 'delegate_resume') return resumeManagedJob(args.jobId, args);
  if (name === 'delegate_review_round') return reviewRoundManagedJob(args.jobId, args);
  if (name === 'delegate_usage') return jobUsage(args.jobId);
  throw brokerError('INVALID_REQUEST', `Unknown tool: ${name}`);
}

function send(message) {
  process.stdout.write(`${JSON.stringify(message)}\n`);
}

const lines = readline.createInterface({ input: process.stdin });
lines.on('line', async (line) => {
  let request;
  try { request = JSON.parse(line); } catch { return; }
  if (request.id == null) return;
  try {
    if (request.method === 'initialize') {
      send({ jsonrpc: '2.0', id: request.id, result: {
        protocolVersion: request.params?.protocolVersion || '2025-11-25',
        capabilities: { tools: { listChanged: false } },
        serverInfo: { name: 'delegate-control', version: '0.24.3' }
      } });
    } else if (request.method === 'tools/list') send({ jsonrpc: '2.0', id: request.id, result: { tools: TOOLS } });
    else if (request.method === 'tools/call') {
      const result = await dispatch(request.params?.name, request.params?.arguments || {});
      send({ jsonrpc: '2.0', id: request.id, result: { content: [{ type: 'text', text: JSON.stringify(result, null, 2) }] } });
    } else send({ jsonrpc: '2.0', id: request.id, error: { code: -32601, message: `Method not found: ${request.method}` } });
  } catch (error) {
    const typed = normalizeBrokerError(error, {
      provider: request.params?.arguments?.provider,
      defaultCode: 'INTERNAL'
    });
    const payload = { error: typed.message, code: typed.code, retryable: typed.retryable, provider: typed.provider || null };
    if (typed.currentRevision != null) payload.currentRevision = typed.currentRevision;
    if (typed.activeJobId) payload.activeJobId = typed.activeJobId;
    send({ jsonrpc: '2.0', id: request.id, result: { isError: true, content: [{ type: 'text', text: JSON.stringify(payload, null, 2) }] } });
  }
});

try { maybePruneJobs(); } catch {}
