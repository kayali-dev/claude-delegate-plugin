#!/usr/bin/env node
import readline from 'node:readline';
import { brokerError, normalizeBrokerError } from './lib/errors.mjs';
import { enabledProviders } from './lib/state.mjs';
import { aggregateAudit, readAuditLog } from './lib/stats.mjs';
import {
  capEventsBySize,
  diffStat,
  filterDiffPaths,
  groupSummary,
  inspectJob,
  jobDiff,
  jobFiles,
  jobTranscriptPage,
  jobUsage,
  launchManagedJob,
  listManagedJobs,
  maybePruneJobs,
  readJobEventPage,
  reviewRoundManagedJob,
  resumeManagedJob,
  sliceDiff,
  sliceResultText,
  submitControl,
  waitForJob
} from './lib/control.mjs';

