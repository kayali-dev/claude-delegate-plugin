#!/usr/bin/env node
import { avoidPercentFor, effectiveUsage, loadState } from './lib/state.mjs';

let input = '';
for await (const chunk of process.stdin) input += chunk;

try {
  const event = JSON.parse(input || '{}');
  const toolName = event.tool_name || event.toolName || '';
  const toolInput = event.tool_input || event.toolInput || {};
  let provider = null;
  let continuation = false;
  // Match by suffix: harnesses may prefix plugin MCP tools (for example
  // mcp__plugin_delegate-router_delegate_control__delegate_start).
  if (/(?:^|_)delegate_codex__codex$/.test(toolName)) provider = 'codex';
  if (/(?:^|_)delegate_codex__codex-reply$/.test(toolName)) {
    provider = 'codex';
    continuation = true;
  }
  if (/(?:^|_)delegate_control__delegate_start$/.test(toolName)) provider = toolInput.provider || null;
  if (/(?:^|_)delegate_control__delegate_resume$/.test(toolName)) {
    const jobId = String(toolInput.jobId || '');
    provider = jobId.startsWith('codex-') ? 'codex' : jobId.startsWith('cursor-') ? 'cursor' : null;
    continuation = true;
  }
  if (toolName === 'Skill') {
    const skill = String(toolInput.skill || toolInput.name || '');
    if (/^codex:(?:review|adversarial-review|rescue)$/.test(skill)) provider = 'codex';
    continuation = /(?:^|\s)--resume(?:\s|$)/.test(String(toolInput.args || toolInput.arguments || ''));
  }
  if (!provider) process.exit(0);

  const overrides = String(process.env.DELEGATE_ALLOW_OVER_LIMIT || '')
    .split(',').map((value) => value.trim()).filter(Boolean);
  if (overrides.includes(provider) || overrides.includes('all')) process.exit(0);

  const threshold = continuation ? 98 : avoidPercentFor(provider);
  const current = effectiveUsage(loadState(), provider);
  if (current.known && current.usedPercent >= threshold) {
    console.error(
      `Blocked ${provider} ${continuation ? 'continuation' : 'delegation'} at ${current.usedPercent}% usage (threshold ${threshold}%). ` +
      `Choose an eligible fallback. The user can explicitly override with DELEGATE_ALLOW_OVER_LIMIT=${provider}.`
    );
    process.exit(2);
  }
} catch (error) {
  console.error(`Delegate quota hook could not read usage state: ${error.message}`);
  process.exit(2);
}
