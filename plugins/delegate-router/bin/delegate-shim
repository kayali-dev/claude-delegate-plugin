#!/usr/bin/env node
// Stable PATH entry point: resolves the *installed* delegate-router plugin from
// Claude Code's plugin registry and execs the matching binary, so ~/.local/bin
// symlinks keep working across plugin versions. Falls back to the sibling
// binary in this checkout when no installed copy is available.
import fs from 'node:fs';
import os from 'node:os';
import path from 'node:path';
import { spawnSync } from 'node:child_process';
import { fileURLToPath } from 'node:url';

const name = path.basename(process.argv[1]);
const self = fs.realpathSync(fileURLToPath(import.meta.url));
if (name === 'delegate-shim') {
  console.error('delegate-shim is not invoked directly; symlink a delegate-* command name to it');
  process.exit(2);
}

function pluginVersion(directory, fallback = '?') {
  try {
    const manifest = JSON.parse(fs.readFileSync(path.join(directory, 'package.json'), 'utf8'));
    return typeof manifest.version === 'string' && manifest.version.trim() ? manifest.version.trim() : fallback;
  } catch {
    return fallback;
  }
}

function installedTarget() {
  try {
    const registryPath = path.join(os.homedir(), '.claude', 'plugins', 'installed_plugins.json');
    const registry = JSON.parse(fs.readFileSync(registryPath, 'utf8'));
    const entries = registry.plugins?.['delegate-router@delegate-skill'] || [];
    const entry = entries.find((item) => item.scope === 'user') || entries[0];
    if (!entry?.installPath) return { target: null, reason: 'lookup' };
    const candidate = path.join(entry.installPath, 'bin', name);
    if (fs.existsSync(candidate)) return { target: candidate, reason: null };
    return {
      target: null,
      reason: 'missing-binary',
      installedVersion: typeof entry.version === 'string' && entry.version.trim()
        ? entry.version.trim() : pluginVersion(entry.installPath)
    };
  } catch {
    return { target: null, reason: 'lookup' };
  }
}

const fallback = path.join(path.dirname(self), name);
const installed = installedTarget();
const fallbackExists = fs.existsSync(fallback);
let target = installed.target;
if (!target && fallbackExists) {
  const siblingVersion = pluginVersion(path.dirname(path.dirname(fallback)));
  const warning = installed.reason === 'missing-binary'
    ? `delegate-shim: installed ${installed.installedVersion} lacks ${name}; falling back to sibling ${siblingVersion}`
    : `delegate-shim: installed registry lookup failed; falling back to sibling ${siblingVersion}`;
  console.error(warning);
  target = fallback;
}
if (!target) {
  console.error(`delegate-shim: cannot resolve ${name}: plugin is not installed and no checkout sibling exists`);
  process.exit(127);
}
if (process.env.DELEGATE_SHIM_DEBUG === '1') console.error(`delegate-shim: ${name} -> ${target}`);
const result = spawnSync(process.execPath, [target, ...process.argv.slice(2)], { stdio: 'inherit' });
process.exit(result.status ?? 1);
