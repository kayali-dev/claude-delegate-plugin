#!/usr/bin/env node
import fs from 'node:fs';
import os from 'node:os';
import path from 'node:path';
import { dataDir, enabledProviders, providerConfigPath, saveEnabledProviders } from './lib/state.mjs';

const args = process.argv.slice(2);
const command = args.shift() || 'show';

function claudeSettingsPath() {
  return process.env.DELEGATE_CLAUDE_SETTINGS || path.join(os.homedir(), '.claude', 'settings.json');
}

function statuslineStatePath() {
  return path.join(dataDir(), 'statusline.json');
}

function wrapperPath() {
  return path.join(dataDir(), 'statusline-wrapper.sh');
}

function readSettings(file) {
  try {
    return JSON.parse(fs.readFileSync(file, 'utf8'));
  } catch (error) {
    if (error.code === 'ENOENT') return {};
    throw new Error(`Cannot read ${file}: ${error.message}`);
  }
}

function writeSettings(file, settings) {
  fs.mkdirSync(path.dirname(file), { recursive: true });
  const temporary = `${file}.${process.pid}.tmp`;
  fs.writeFileSync(temporary, `${JSON.stringify(settings, null, 2)}\n`, { mode: 0o600 });
  fs.renameSync(temporary, file);
}

function captureCommand() {
  const userBin = process.env.DELEGATE_USER_BIN || path.join(os.homedir(), '.local', 'bin');
  return path.join(userBin, 'delegate-claude-usage');
}

function writeWrapper(originalCommand) {
  const capture = captureCommand();
  const body = originalCommand
    ? `#!/usr/bin/env bash
# Generated by delegate-router (delegate-config statusline enable).
# Forwards the official Claude Code status-line payload to delegate-claude-usage
# so provider routing sees Claude's five-hour and weekly windows, then runs the
# original status line unchanged. Remove with: delegate-config statusline disable
input=$(cat)
printf '%s' "$input" | "${capture}" --quiet >/dev/null 2>&1 || true
printf '%s' "$input" | { ${originalCommand} ; }
`
    : `#!/usr/bin/env bash
# Generated by delegate-router (delegate-config statusline enable).
# No prior status line was configured: delegate-claude-usage records Claude's
# five-hour and weekly windows and renders a minimal status line.
# Remove with: delegate-config statusline disable
exec "${capture}"
`;
  fs.mkdirSync(dataDir(), { recursive: true, mode: 0o700 });
  fs.writeFileSync(wrapperPath(), body, { mode: 0o700 });
  try { fs.chmodSync(wrapperPath(), 0o700); } catch {}
  return wrapperPath();
}

function statuslineEnable() {
  const file = claudeSettingsPath();
  const settings = readSettings(file);
  const current = settings.statusLine || null;
  if (current?.command === wrapperPath()) {
    const saved = JSON.parse(fs.readFileSync(statuslineStatePath(), 'utf8'));
    writeWrapper(saved.original?.command || null);
    return { status: 'already-enabled', settingsFile: file, wrapper: wrapperPath() };
  }
  if (current && current.type !== 'command') {
    throw new Error(`statusLine type '${current.type}' is not wrappable; integrate delegate-claude-usage manually`);
  }
  fs.mkdirSync(dataDir(), { recursive: true, mode: 0o700 });
  fs.writeFileSync(statuslineStatePath(), `${JSON.stringify({ version: 1, settingsFile: file, original: current }, null, 2)}\n`, { mode: 0o600 });
  const wrapper = writeWrapper(current?.command || null);
  settings.statusLine = { ...(current || { type: 'command' }), type: 'command', command: wrapper };
  writeSettings(file, settings);
  return { status: 'enabled', settingsFile: file, wrapper, wrappedExisting: Boolean(current) };
}

function statuslineDisable() {
  const file = claudeSettingsPath();
  const settings = readSettings(file);
  let original = null;
  try { original = JSON.parse(fs.readFileSync(statuslineStatePath(), 'utf8')).original; } catch {}
  if (settings.statusLine?.command !== wrapperPath() && !original) {
    return { status: 'not-enabled', settingsFile: file };
  }
  if (original) settings.statusLine = original;
  else delete settings.statusLine;
  writeSettings(file, settings);
  try { fs.rmSync(wrapperPath(), { force: true }); } catch {}
  try { fs.rmSync(statuslineStatePath(), { force: true }); } catch {}
  return { status: 'disabled', settingsFile: file, restored: original || null };
}

function statuslineShow() {
  const settings = readSettings(claudeSettingsPath());
  return {
    settingsFile: claudeSettingsPath(),
    statusLine: settings.statusLine || null,
    captureEnabled: settings.statusLine?.command === wrapperPath()
  };
}

try {
  if (command === 'show') {
    console.log(JSON.stringify({ configFile: providerConfigPath(), enabled: enabledProviders() }, null, 2));
  } else if (command === 'providers') {
    const mode = args[0];
    const providers = mode === 'both' ? ['codex', 'cursor'] : mode === 'codex' ? ['codex'] : mode === 'cursor' ? ['cursor'] : null;
    if (!providers) throw new Error('expected codex, cursor, or both');
    console.log(JSON.stringify({ configFile: providerConfigPath(), enabled: saveEnabledProviders(providers) }, null, 2));
  } else if (command === 'statusline') {
    const action = args[0] || 'show';
    if (action === 'enable') console.log(JSON.stringify(statuslineEnable(), null, 2));
    else if (action === 'disable') console.log(JSON.stringify(statuslineDisable(), null, 2));
    else if (action === 'show') console.log(JSON.stringify(statuslineShow(), null, 2));
    else throw new Error('expected statusline enable|disable|show');
  } else {
    console.error('Usage: delegate-config show | providers <codex|cursor|both> | statusline <enable|disable|show>');
    process.exit(command === 'help' ? 0 : 2);
  }
} catch (error) {
  console.error(`delegate-config: ${error.message}`);
  process.exit(1);
}
