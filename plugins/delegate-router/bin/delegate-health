#!/usr/bin/env node
import { spawnSync } from 'node:child_process';
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { inspectJob, launchManagedJob } from './lib/control.mjs';
import { normalizeBrokerError } from './lib/errors.mjs';
import { availableModelIds, executableOnPath, resolveCursorBinary } from './lib/cursor.mjs';
import { auditLogPath, effectiveUsage, enabledProviders, loadState, mutateState, providerEnabled, providerNames, providerConfigPath, statePath } from './lib/state.mjs';

function run(command, args, timeout = 12000, maxOutput = 2000) {
  const result = spawnSync(command, args, { encoding: 'utf8', timeout, windowsHide: true });
  return {
    ok: result.status === 0,
    status: result.status,
    output: (result.stdout || result.stderr || '').trim().slice(0, maxOutput)
  };
}

const args = process.argv.slice(2);
const quick = args.includes('--quick');
const deep = args.includes('--deep');
const state = loadState();
const cursorBinary = resolveCursorBinary();
const codexBinary = process.env.DELEGATE_CODEX_BIN || executableOnPath('codex');
const claudeBinary = executableOnPath('claude');
const controlServer = path.join(path.dirname(fileURLToPath(import.meta.url)), 'delegate-control-mcp');
const configuredProviders = enabledProviders();
const packageInfo = JSON.parse(fs.readFileSync(path.join(path.dirname(fileURLToPath(import.meta.url)), '..', 'package.json'), 'utf8'));
const report = {
  ok: true,
  version: packageInfo.version,
  versionNote: 'CLI resolves to the installed plugin on every run; the skill and MCP servers pin at session start - reload plugins after upgrades to align all surfaces',
  stateFile: statePath(),
  auditLogFile: auditLogPath(),
  providerConfigFile: providerConfigPath(),
  enabledProviders: configuredProviders,
  node: { ok: Number(process.versions.node.split('.')[0]) >= 18, version: process.versions.node },
  claude: { installed: Boolean(claudeBinary), path: claudeBinary },
  codex: { enabled: providerEnabled('codex'), installed: Boolean(codexBinary), path: codexBinary },
  cursor: { enabled: providerEnabled('cursor'), installed: Boolean(cursorBinary), path: cursorBinary },
  control: { installed: fs.existsSync(controlServer), path: controlServer, protocol: 'MCP stdio' },
  usage: Object.fromEntries(providerNames().map((name) => [name, effectiveUsage(state, name)]))
};
if (report.usage.cursor && !report.usage.cursor.known) {
  report.usage.cursor.note = 'expected: Cursor exposes no allowance API; record the dashboard percentage manually with delegate-usage set cursor <percent> --window first-party';
}

if (report.codex.enabled && codexBinary) report.codex.version = run(codexBinary, ['--version'], 5000);
if (report.cursor.enabled && cursorBinary) {
  report.cursor.version = run(cursorBinary, ['--version'], 5000);
  if (!quick) {
    report.cursor.acp = run(cursorBinary, ['acp', '--help'], 10000);
    report.cursor.status = run(cursorBinary, ['status'], 15000);
    const models = availableModelIds(cursorBinary, 15000);
    report.cursor.models = {
      ok: models.length > 0,
      count: models.length,
      composer: models.filter((id) => /^composer-/.test(id)),
      grok: models.filter((id) => /^grok-/.test(id))
    };
  }
}
if (claudeBinary && !quick) {
  const plugins = run(claudeBinary, ['plugin', 'list', '--json'], 15000, 200000);
  report.claude.pluginsQuery = { ok: plugins.ok };
  if (plugins.ok) {
    try {
      const parsed = JSON.parse(plugins.output);
      const serialized = JSON.stringify(parsed);
      report.claude.officialCodexPlugin = serialized.includes('codex@openai-codex');
    } catch {
      report.claude.officialCodexPlugin = null;
    }
  }
}

async function deepProbe(provider) {
  const startedAt = Date.now();
  const version = provider === 'codex' ? report.codex.version : report.cursor.version;
  const cliVersion = String(version?.output || '').match(/\b\d+\.\d+(?:\.\d+)?\b/)?.[0] || null;
  let entry;
  try {
    const available = provider === 'codex' ? report.codex.installed : report.cursor.installed;
    if (!available) throw Object.assign(new Error(`${provider} CLI is unavailable`), { code: 'TRANSPORT_ERROR' });
    const job = launchManagedJob({
      provider,
      model: 'auto',
      mode: 'consult',
      cwd: process.cwd(),
      timeoutSeconds: 120,
      maxOutputTokens: 2000,
      prompt: '# Objective\nHealth probe: Reply with exactly: ok\n\n# Allowed scope\nRead-only; do not write files.\n\n# Acceptance criteria\nThe response is exactly ok.\n\n# Return\nok'
    });
    let current = inspectJob(job.id);
    const deadline = Date.now() + 125000;
    while (!['completed', 'failed', 'cancelled'].includes(current.status) && Date.now() < deadline) {
      await new Promise((resolve) => setTimeout(resolve, 100));
      current = inspectJob(job.id);
    }
    const ok = current.status === 'completed' && String(current.resultText || '').trim().toLowerCase() === 'ok';
    entry = {
      provider,
      ok,
      durationMs: Date.now() - startedAt,
      cliVersion,
      at: Date.now(),
      ...(!ok ? { errorCode: current.errorCode || (current.status === 'completed' ? 'PROBE_RESPONSE' : 'TIMEOUT') } : {})
    };
  } catch (error) {
    const typed = normalizeBrokerError(error, { provider, defaultCode: 'TRANSPORT_ERROR' });
    entry = { provider, ok: false, durationMs: Date.now() - startedAt, cliVersion, at: Date.now(), errorCode: typed.code };
  }
  mutateState((current) => {
    current.lastVerified ||= {};
    current.lastVerified[provider] = entry;
  });
  return entry;
}

if (deep) {
  report.deepAllowanceSpend = true;
  report.lastVerified = [];
  for (const provider of configuredProviders) report.lastVerified.push(await deepProbe(provider));
}

report.ok = report.node.ok && report.claude.installed && report.control.installed
  && (!report.codex.enabled || report.codex.installed)
  && (!report.cursor.enabled || report.cursor.installed);
if (!quick && report.cursor.enabled && report.cursor.installed) {
  report.ok = report.ok && report.cursor.status?.ok === true && report.cursor.models?.ok === true;
}
if (deep) report.ok = report.ok && report.lastVerified.every((entry) => entry.ok);
if (args.includes('--json')) console.log(JSON.stringify(report, null, 2));
else {
  console.log(`Delegate Router ${report.version}${deep ? ' deep health (spends real provider allowance)' : ''}: ${report.ok ? 'ready' : 'degraded'} (CLI tracks the installed plugin; skill/MCP pin at session start)`);
  console.log(`Claude: ${report.claude.installed ? 'installed' : 'missing'}`);
  console.log(`Enabled providers: ${configuredProviders.join(', ')}`);
  console.log(`Codex: ${report.codex.enabled ? report.codex.installed ? 'installed' : 'missing' : 'disabled'}`);
  console.log(`Cursor: ${report.cursor.enabled ? report.cursor.installed ? 'installed' : 'missing' : 'disabled'}${report.cursor.enabled && cursorBinary ? ` (${path.basename(cursorBinary)})` : ''}`);
  console.log(`Control MCP: ${report.control.installed ? 'installed' : 'missing'}`);
  console.log(`Audit log: ${report.auditLogFile}`);
  if (report.cursor.acp) console.log(`Cursor ACP: ${report.cursor.acp.ok ? 'available' : 'unavailable (headless fallback)'}`);
  if (report.cursor.models) console.log(`Cursor models: ${report.cursor.models.count}`);
  for (const entry of report.lastVerified || []) console.log(`${entry.provider} live probe: ${entry.ok ? 'ok' : `failed (${entry.errorCode})`} in ${entry.durationMs}ms, CLI ${entry.cliVersion || 'unknown'}`);
  for (const name of providerNames()) {
    const current = report.usage[name];
    console.log(`${name} usage: ${current.known ? `${+current.usedPercent.toFixed(2)}%` : 'unknown'}`);
  }
}
