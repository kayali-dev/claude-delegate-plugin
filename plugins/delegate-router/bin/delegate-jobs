#!/usr/bin/env node
import fs from 'node:fs';
import { normalizeBrokerError } from './lib/errors.mjs';
import { terminatePid } from './lib/process.mjs';
import {
  backfillAuditLog,
  diffStat,
  filterDiffPaths,
  groupSummary,
  inspectJob,
  jobDiff,
  jobFiles,
  jobTranscript,
  jobUsage,
  launchManagedJob,
  pruneJobs,
  readJobEventPage,
  reconcileJob,
  reviewRoundManagedJob,
  revertManagedJob,
  resumeManagedJob,
  sliceDiff,
  sliceResultText,
  submitControl,
  waitForJob
} from './lib/control.mjs';
import { listJobs, saveJob } from './lib/state.mjs';
import { aggregateAuditStats, readAuditLog } from './lib/stats.mjs';

function usage() {
  console.log(`Usage:
  delegate-jobs start --provider codex|cursor --prompt <objective> [--profile name] [--model id] [--mode mode] [--cwd path] [--effort low|medium|high|xhigh|max|ultra] [--timeout-seconds N] [--max-output-tokens N] [--idempotency-key key] [--group id] [--start-paused] [--ingest-files /abs/a,/abs/b] [--auto-nudge] [--report-schema json|--report-schema-file path] [--retry-max-attempts N --retry-on transport,rate-limit] [--verify-command command --verify-timeout-seconds N] [--network] [--network-allow domain,*.domain] [--sandbox auto|off] [--add-dir path ...] [--approve-mcps] [--cursor-worktree [--cursor-worktree-base path]] [--allowed-paths a,b] [--allow-sensitive] [--override-limit] [--override-writer] [--override-lane] [--dry-run] [--wait] [--wait-for session|turn|first-output|--wait-for-session]
  delegate-jobs status|list [job-id] [--limit N] [--active] [--status s] [--group id] [--json]
  delegate-jobs group <id> [--json]
  delegate-jobs stats [--since 7d|24h] [--json]
  delegate-jobs audit backfill [--json]
  delegate-jobs inspect <job-id> [--json]
  delegate-jobs events <job-id> [--after N] [--limit N] [--types a,b] [--follow] [--json]
  delegate-jobs transcript <job-id> [--after N] [--limit N] [--verbose] [--json]
  delegate-jobs wait <job-id> [--timeout-seconds N]   # exits 0 completed, 3 failed, 4 cancelled, 5 no changes, 6 verification failed, 75 timeout
  delegate-jobs diff <job-id> [--stat] [--offset N] [--max-chars N] [--paths a,b]
  delegate-jobs files <job-id> [--json]
  delegate-jobs steer <job-id> --expected-revision N --prompt <correction> [--strategy auto|same-turn|restart|next-turn]
  delegate-jobs cancel <job-id> [--expected-revision N]
  delegate-jobs release <job-id> [--expected-revision N]
  delegate-jobs respond <job-id> --expected-revision N [--request-id id] [--answer text|--accept|--reject|--response-json json] [--command-id id]
  delegate-jobs resume <job-id> --prompt <text> [--model id] [--mode mode] [--cwd path] [--effort level] [--timeout-seconds N] [--max-output-tokens N] [--retry-max-attempts N --retry-on transport,rate-limit] [--verify-command command --verify-timeout-seconds N] [--network] [--network-allow domain,*.domain] [--sandbox auto|off] [--add-dir path ...] [--approve-mcps] [--cursor-worktree [--cursor-worktree-base path]] [--allowed-paths a,b] [--allow-sensitive] [--override-limit] [--override-writer]
  delegate-jobs review-round <job-id> --prompt <findings-or-file> [--prompt-file path]
  delegate-jobs revert <job-id> [--dry-run]
  delegate-jobs usage <job-id> [--json]
  delegate-jobs result <job-id> [--find text] [--offset N] [--max-chars N] [--json]
  delegate-jobs logs <job-id> [--stderr]
  delegate-jobs prune [--max-age-days N]`);
}

function value(args, flag, fallback = undefined) {
  const index = args.indexOf(flag);
  return index >= 0 ? args[index + 1] : fallback;
}

function values(args, flag) {
  const result = [];
  for (let index = 0; index < args.length; index += 1) if (args[index] === flag && args[index + 1] != null) result.push(args[++index]);
  return result;
}

function prompt(args) {
  const file = value(args, '--prompt-file');
  return file ? fs.readFileSync(file, 'utf8') : value(args, '--prompt');
}

function retryPolicy(args) {
  const maxAttempts = value(args, '--retry-max-attempts');
  const retryOn = value(args, '--retry-on');
  if (maxAttempts == null && retryOn == null) return undefined;
  return {
    maxAttempts: maxAttempts == null ? undefined : Number(maxAttempts),
    retryOn: retryOn == null ? undefined : retryOn.split(',').map((item) => item.trim()).filter(Boolean)
  };
}

function verifyOption(args) {
  const command = value(args, '--verify-command');
  const timeoutSeconds = value(args, '--verify-timeout-seconds');
  if (command == null && timeoutSeconds == null) return undefined;
  return { command, ...(timeoutSeconds == null ? {} : { timeoutSeconds: Number(timeoutSeconds) }) };
}

function reportSchemaOption(args) {
  const file = value(args, '--report-schema-file');
  const raw = file ? fs.readFileSync(file, 'utf8') : value(args, '--report-schema');
  if (raw == null) return undefined;
  return JSON.parse(raw);
}

function requireJob(id) {
  if (!id) throw new Error('job id is required');
  return reconcileJob(id);
}

function json(value) { console.log(JSON.stringify(value, null, 2)); }
function terminal(status) { return ['completed', 'failed', 'cancelled'].includes(status); }

function displayModel(job) {
  const clean = (value) => String(value || '').replace(/\[\]$/, '');
  const stored = clean(job.model || job.requestedModel);
  const requested = clean(job.requestedModel || job.model);
  const resolved = clean(job.resolvedModel);
  if (requested === 'auto') {
    return resolved && resolved !== 'auto' && resolved !== 'default' ? `auto \u2192 ${resolved}` : 'auto';
  }
  if (!stored) return resolved;
  if (stored !== requested || !resolved || resolved === stored || resolved === requested) return stored;
  return `${stored} \u2192 ${resolved}`;
}

function renderVerificationOrigin(job) {
  if (job.verificationOrigin === 'worker-sandbox') {
    console.error(`verification: worker-sandbox — worker-reported checks are partial evidence; re-run checks on the real tree (${job.id})`);
  }
}

// review-round may emit packet-lint diagnostics while it assembles and launches
// the continuation. Keep stdout exclusively JSON for callers that pipe it.
function withStdoutDiagnosticsRedirected(action) {
  const originalWrite = process.stdout.write;
  process.stdout.write = process.stderr.write.bind(process.stderr);
  try { return action(); }
  finally { process.stdout.write = originalWrite; }
}

const args = process.argv.slice(2);
const rawCommand = args.shift() || 'status';
const command = rawCommand === 'list' ? 'status' : rawCommand;

try {
  if (command === 'start') {
    const rawTimeout = value(args, '--timeout-seconds');
    const rawMaxOutputTokens = value(args, '--max-output-tokens');
    const started = launchManagedJob({
      provider: value(args, '--provider'), model: value(args, '--model'), mode: value(args, '--mode'), profile: value(args, '--profile'),
      cwd: value(args, '--cwd', process.cwd()), approval: value(args, '--approval', 'auto'), prompt: prompt(args), transport: value(args, '--transport'),
      effort: value(args, '--effort'), timeoutSeconds: rawTimeout == null ? null : Number(rawTimeout),
      maxOutputTokens: rawMaxOutputTokens == null ? null : Number(rawMaxOutputTokens),
      idempotencyKey: value(args, '--idempotency-key'),
      groupId: value(args, '--group'), startPaused: args.includes('--start-paused'),
      ingestFiles: value(args, '--ingest-files')?.split(',').map((item) => item.trim()).filter(Boolean),
      autoNudge: args.includes('--auto-nudge'), reportSchema: reportSchemaOption(args),
      retryPolicy: retryPolicy(args), verify: verifyOption(args),
      network: args.includes('--network'), sandbox: value(args, '--sandbox'),
      networkAllow: value(args, '--network-allow')?.split(',').map((item) => item.trim()).filter(Boolean),
      addDirs: values(args, '--add-dir'), approveMcps: args.includes('--approve-mcps'),
      cursorWorktree: args.includes('--cursor-worktree'), cursorWorktreeBase: value(args, '--cursor-worktree-base'),
      allowedPaths: value(args, '--allowed-paths')?.split(',').map((item) => item.trim()).filter(Boolean),
      allowSensitive: args.includes('--allow-sensitive'), overrideLimit: args.includes('--override-limit'),
      overrideWriter: args.includes('--override-writer'), overrideLane: args.includes('--override-lane'),
      dryRun: args.includes('--dry-run')
    });
    const waitFor = value(args, '--wait-for') ?? (args.includes('--wait-for-session') ? 'session' : null);
    if (started.dryRun) json(started);
    else if (waitFor) json(await waitForJob(started.id, waitFor));
    else json(started);
    if (!started.dryRun && args.includes('--wait')) {
      let job = requireJob(started.id);
      while (!terminal(job.status)) {
        await new Promise((resolve) => setTimeout(resolve, 1000));
        job = requireJob(started.id);
      }
      if (job.status !== 'completed') process.exit(job.status === 'failed' ? 3 : 4);
      if (job.verification?.exitCode) process.exit(6);
      if (['implement', 'verify'].includes(job.mode) && !(job.changedFiles?.count > 0)) process.exit(5);
    }
  } else if (command === 'status') {
    // A bare positional is a job id — but flag values (--limit 3) must not be
    // mistaken for one.
    const valueFlags = new Set(['--limit', '--status', '--group']);
    let id;
    for (let i = 0; i < args.length; i += 1) {
      if (args[i].startsWith('--')) { if (valueFlags.has(args[i])) i += 1; continue; }
      id = args[i];
      break;
    }
    const statusFilter = value(args, '--status');
    let jobs = id ? [requireJob(id)] : listJobs().map((job) => (job.status === 'running' ? reconcileJob(job.id) : job));
    if (args.includes('--active')) jobs = jobs.filter((job) => !terminal(job.status));
    if (statusFilter) jobs = jobs.filter((job) => job.status === statusFilter);
    const groupId = value(args, '--group');
    if (groupId) jobs = jobs.filter((job) => job.groupId === groupId);
    if (!id) jobs = jobs.slice(0, Number(value(args, '--limit', 20)));
    if (args.includes('--json')) json(jobs);
    else if (!jobs.length) console.log('No delegation jobs.');
    else {
      console.log('Job ID                         Provider Status     Phase       Model');
      for (const job of jobs) console.log(`${job.id.padEnd(30)} ${(job.provider || '').padEnd(8)} ${(job.status || '').padEnd(10)} ${(job.phase || '').padEnd(11)} ${displayModel(job)}`);
    }
    for (const job of jobs) renderVerificationOrigin(job);
  } else if (command === 'group') {
    json(groupSummary(args[0]));
  } else if (command === 'stats') {
    const stats = aggregateAuditStats(readAuditLog(), { since: value(args, '--since') });
    if (args.includes('--json')) json(stats);
    else if (!stats.groups.length) console.log('No audited delegation jobs in the selected window.');
    else {
      console.log(`Delegation stats${stats.since ? ` (last ${stats.since})` : ''}: ${stats.jobs} jobs`);
      console.log('Provider Model            Mode       Jobs Success Resume Nudge Mean ms Median ms Mean out Budget Timeout Violations');
      for (const row of stats.groups) {
        const percent = `${Math.round(row.successRate * 100)}%`;
        console.log(`${row.provider.padEnd(8)} ${row.model.padEnd(16)} ${row.mode.padEnd(10)} ${String(row.jobs).padStart(4)} ${percent.padStart(7)} ${String(row.resumedJobs).padStart(6)} ${String(row.nudgeCount).padStart(5)} ${String(Math.round(row.meanDurationMs || 0)).padStart(7)} ${String(Math.round(row.medianDurationMs || 0)).padStart(9)} ${String(Math.round(row.meanOutputTokens || 0)).padStart(8)} ${String(row.budgetCount).padStart(6)} ${String(row.timeoutCount).padStart(7)} ${String(row.violationCount).padStart(10)}`);
      }
    }
  } else if (command === 'audit') {
    if (args[0] !== 'backfill') throw new Error("audit subcommand must be 'backfill'");
    const result = backfillAuditLog();
    if (args.includes('--json')) json(result);
    else console.log(`Scanned ${result.scanned} terminal jobs; backfilled ${result.backfilled}.`);
  } else if (command === 'inspect') {
    json(inspectJob(args[0]));
  } else if (command === 'events') {
    const id = args[0];
    let afterSeq = Number(value(args, '--after', 0));
    const limit = Number(value(args, '--limit', 200));
    do {
      const types = value(args, '--types');
      const page = readJobEventPage(id, { afterSeq, limit, ...(types ? { types: types.split(',') } : {}) });
      const events = page.events;
      if (args.includes('--json')) for (const event of events) console.log(JSON.stringify(event));
      else for (const event of events) console.log(`${String(event.seq).padStart(5)} ${new Date(event.at).toISOString()} ${event.type} ${JSON.stringify(event.data)}`);
      afterSeq = page.nextSeq;
      const job = requireJob(id);
      if (!args.includes('--follow') || terminal(job.status)) break;
      await new Promise((resolve) => setTimeout(resolve, 500));
    } while (true);
  } else if (command === 'transcript') {
    json(jobTranscript(args[0], {
      afterSeq: Number(value(args, '--after', 0)),
      limit: Number(value(args, '--limit', 1000)),
      verbose: args.includes('--verbose')
    }));
  } else if (command === 'wait') {
    const waitValueFlags = new Set(['--timeout-seconds']);
    let id;
    for (let i = 0; i < args.length; i += 1) {
      if (args[i].startsWith('--')) { if (waitValueFlags.has(args[i])) i += 1; continue; }
      id = args[i];
      break;
    }
    const timeoutSeconds = Number(value(args, '--timeout-seconds', 0));
    const deadline = timeoutSeconds > 0 ? Date.now() + timeoutSeconds * 1000 : null;
    let job = requireJob(id);
    while (!terminal(job.status)) {
      if (deadline && Date.now() > deadline) {
        console.error(`${job.id} is still ${job.status} after ${timeoutSeconds}s`);
        process.exit(75);
      }
      await new Promise((resolve) => setTimeout(resolve, 1000));
      job = requireJob(id);
    }
    json({ id: job.id, status: job.status, model: job.model, session: job.providerSessionId || job.session, usage: job.usage, durationMs: job.durationMs, changedFiles: job.changedFiles || null, verification: job.verification || null, result: job.result, error: job.error });
    if (job.status !== 'completed') process.exit(job.status === 'failed' ? 3 : 4);
    if (job.verification?.exitCode) {
      console.error(`${job.id} completed but verification exited ${job.verification.exitCode}`);
      process.exit(6);
    }
    // "completed" means the turn ended, not that the objective was met. A
    // write-mode job that finished with zero observed changes is a strong
    // signal the objective was not met; give it a distinct exit code.
    if (['implement', 'verify'].includes(job.mode) && !(job.changedFiles?.count > 0)) {
      console.error(`${job.id} completed but no file changes were observed`);
      process.exit(5);
    }
    process.exit(0);
  } else if (command === 'prune') {
    const rawDays = value(args, '--max-age-days');
    json(pruneJobs(rawDays == null ? {} : { maxAgeDays: Number(rawDays) }));
  } else if (command === 'revert') {
    json(revertManagedJob(args[0], { dryRun: args.includes('--dry-run') }));
  } else if (command === 'diff') {
    const full = filterDiffPaths(jobDiff(args[0]), value(args, '--paths')?.split(',').map((item) => item.trim()).filter(Boolean));
    if (args.includes('--stat')) json(diffStat(full));
    else if (value(args, '--offset') != null || value(args, '--max-chars') != null) {
      json(sliceDiff(full, { offset: Number(value(args, '--offset', 0)), maxChars: Number(value(args, '--max-chars', 100000)) }));
    } else process.stdout.write(full);
  } else if (command === 'files') {
    json(jobFiles(args[0]));
  } else if (command === 'steer') {
    const rawRevision = value(args, '--expected-revision');
    const expectedRevision = rawRevision == null ? null : Number(rawRevision);
    json(submitControl(args[0], {
      type: 'steer', correctionId: value(args, '--correction-id'), strategy: value(args, '--strategy', 'auto'),
      expectedTurnId: value(args, '--expected-turn'), text: prompt(args)
    }, expectedRevision));
  } else if (command === 'cancel') {
    const job = requireJob(args[0]);
    if (job.managedBy === 'delegate-control') {
      const raw = value(args, '--expected-revision');
      json(submitControl(job.id, { type: 'cancel', commandId: value(args, '--command-id') }, raw == null ? null : Number(raw)));
    } else if (job.status !== 'running') console.log(`${job.id} is already ${job.status}.`);
    else {
      terminatePid(job.pid);
      job.status = 'cancelled';
      job.updatedAt = Math.floor(Date.now() / 1000);
      job.completedAt = job.updatedAt;
      saveJob(job);
      console.log(`Cancellation requested for legacy job ${job.id}.`);
    }
  } else if (command === 'release') {
    const job = requireJob(args[0]);
    const raw = value(args, '--expected-revision');
    const expectedRevision = raw == null ? job.revision : Number(raw);
    json(submitControl(job.id, { type: 'release', commandId: value(args, '--command-id') }, expectedRevision));
  } else if (command === 'respond') {
    const raw = value(args, '--expected-revision');
    const accepts = args.includes('--accept');
    const rejects = args.includes('--reject');
    if (accepts && rejects) throw new Error('choose only one of --accept or --reject');
    const responseJson = value(args, '--response-json');
    json(submitControl(args[0], {
      type: 'respond',
      commandId: value(args, '--command-id'),
      requestId: value(args, '--request-id'),
      answer: value(args, '--answer'),
      ...(accepts || rejects ? { accept: accepts } : {}),
      ...(responseJson ? { response: JSON.parse(responseJson) } : {})
    }, raw == null ? null : Number(raw)));
  } else if (command === 'resume') {
    const rawTimeout = value(args, '--timeout-seconds');
    const rawMaxOutputTokens = value(args, '--max-output-tokens');
    json(resumeManagedJob(args[0], {
      prompt: prompt(args), model: value(args, '--model'), mode: value(args, '--mode'), cwd: value(args, '--cwd'),
      effort: value(args, '--effort'), timeoutSeconds: rawTimeout == null ? undefined : Number(rawTimeout),
      maxOutputTokens: rawMaxOutputTokens == null ? undefined : Number(rawMaxOutputTokens),
      retryPolicy: retryPolicy(args), verify: verifyOption(args),
      network: args.includes('--network') ? true : undefined, sandbox: value(args, '--sandbox'),
      networkAllow: value(args, '--network-allow')?.split(',').map((item) => item.trim()).filter(Boolean),
      addDirs: values(args, '--add-dir').length ? values(args, '--add-dir') : undefined,
      approveMcps: args.includes('--approve-mcps') ? true : undefined,
      cursorWorktree: args.includes('--cursor-worktree') ? true : undefined,
      cursorWorktreeBase: value(args, '--cursor-worktree-base'),
      allowedPaths: value(args, '--allowed-paths')?.split(',').map((item) => item.trim()).filter(Boolean),
      allowSensitive: args.includes('--allow-sensitive') ? true : undefined,
      overrideLimit: args.includes('--override-limit'), overrideWriter: args.includes('--override-writer')
    }));
  } else if (command === 'review-round') {
    const result = withStdoutDiagnosticsRedirected(() => reviewRoundManagedJob(args[0], { prompt: prompt(args) }));
    json(result);
  } else if (command === 'usage') {
    json(jobUsage(args[0]));
  } else if (command === 'result') {
    const job = requireJob(args[0]);
    if (!terminal(job.status)) { console.error(`${job.id} is still ${job.status}.`); process.exit(75); }
    const windowed = args.includes('--find') || value(args, '--offset') != null || value(args, '--max-chars') != null;
    if (windowed) {
      const window = sliceResultText(job.resultText, {
        find: args.includes('--find') ? value(args, '--find') : undefined,
        offset: Number(value(args, '--offset', 0)),
        maxChars: Number(value(args, '--max-chars', 60000))
      });
      if (args.includes('--json')) json({ id: job.id, status: job.status, model: job.model, session: job.providerSessionId || job.session, verificationOrigin: job.verificationOrigin || null, ...window });
      else process.stdout.write(window.resultText);
    } else json({ id: job.id, status: job.status, model: job.model, session: job.providerSessionId || job.session, usage: job.usage, durationMs: job.durationMs, verificationOrigin: job.verificationOrigin || null, result: job.result, error: job.error });
    renderVerificationOrigin(job);
  } else if (command === 'logs') {
    const job = requireJob(args[0]);
    const file = args.includes('--stderr') ? job.stderrPath : job.stdoutPath;
    if (!file || !fs.existsSync(file)) throw new Error('job log is unavailable');
    process.stdout.write(fs.readFileSync(file, 'utf8'));
  } else {
    usage();
    process.exit(command === 'help' ? 0 : 2);
  }
} catch (error) {
  const typed = normalizeBrokerError(error, { defaultCode: 'INTERNAL' });
  console.error(`delegate-jobs: ${typed.message} (retryable=${typed.retryable}${typed.provider ? `, provider=${typed.provider}` : ''})`);
  process.exit(1);
}
