#!/usr/bin/env node
import fs from 'node:fs';
import path from 'node:path';
import { spawn } from 'node:child_process';
import { fileURLToPath } from 'node:url';
import {
  availableModelIds,
  buildCursorArgs,
  cursorLaunchCommand,
  findValue,
  resolveCursorBinary,
  resolveCursorModel,
  runCursor,
  stripPromptArgs
} from './lib/cursor.mjs';
import { terminateProcessTree } from './lib/process.mjs';
import { DeltaRedactor } from './lib/control.mjs';
import { adoptDirectShadow, beginDirectShadow } from './lib/direct-shadow.mjs';
import {
  ActivityTransitionEmitter,
  EphemeralCursorActivity,
  mapCursorHeadlessEvent,
  recordGitState,
  securityPreamble
} from './lib/providers.mjs';
import {
  avoidPercentFor,
  effectiveUsage,
  jobsDir,
  loadState,
  recordEvent,
  saveState,
  setWindow,
  providerEnabled
} from './lib/state.mjs';

function fail(message, code = 2) {
  console.error(`delegate-cursor: ${message}`);
  process.exit(code);
}

function parseArgs(argv) {
  const result = {
    mode: 'consult',
    model: 'composer',
    cwd: process.cwd(),
    approval: 'auto',
    threshold: avoidPercentFor('cursor'),
    timeoutSeconds: Number(process.env.DELEGATE_CURSOR_TIMEOUT_SECONDS || 3600),
    prompt: null,
    promptFile: null,
    resume: null,
    overrideLimit: false,
    overrideLane: false,
    allowSensitive: false,
    sandbox: null,
    background: false,
    dryRun: false,
    jobId: null
  };
  const rest = [];
  for (let i = 0; i < argv.length; i += 1) {
    const value = argv[i];
    if (value === '--override-limit') result.overrideLimit = true;
    else if (value === '--override-lane') result.overrideLane = true;
    else if (value === '--allow-sensitive') result.allowSensitive = true;
    else if (value === '--background') result.background = true;
    else if (value === '--dry-run') result.dryRun = true;
    else if (value === '--model') result.model = argv[++i];
    else if (value === '--mode') result.mode = argv[++i];
    else if (value === '--cwd') result.cwd = argv[++i];
    else if (value === '--approval') result.approval = argv[++i];
    else if (value === '--threshold') result.threshold = Number(argv[++i]);
    else if (value === '--timeout-seconds') result.timeoutSeconds = Number(argv[++i]);
    else if (value === '--sandbox') result.sandbox = argv[++i];
    else if (value === '--resume') result.resume = argv[++i];
    else if (value === '--prompt') result.prompt = argv[++i];
    else if (value === '--prompt-file') result.promptFile = argv[++i];
    else if (value === '--job-id') result.jobId = argv[++i];
    else if (value === '--help' || value === '-h') result.help = true;
    else rest.push(value);
  }
  if (!result.prompt && rest.length) result.prompt = rest.join(' ');
  return result;
}

function usage() {
  console.log(`Usage: delegate-cursor [options] --prompt <task packet>
  --model composer|grok|grok-xhigh|auto|<cursor-model-id>
  --mode consult|plan|review|implement|verify
  --approval auto|force
  --cwd <path>
  --resume <chat-id>
  --prompt-file <path>
  --timeout-seconds <10-86400>
  --sandbox auto|off        (off disables Cursor sandboxing: host CLIs, git, live web)
  --background
  --dry-run
  --allow-sensitive
  --override-limit
  --override-lane           (permit an explicitly user-requested GPT model via Cursor)`);
}

function createJobId() {
  return `cursor-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 8)}`;
}

function directShadowOptions(options, extra = {}) {
  return {
    provider: 'cursor',
    transport: 'direct-cli',
    prompt: options.prompt,
    cwd: options.cwd,
    model: extra.model || options.model,
    resolvedModel: extra.resolvedModel || null,
    mode: options.mode,
    effort: null,
    sandbox: options.sandbox === 'off' ? 'off' : 'auto',
    approval: options.approval,
    providerSessionId: options.resume,
    pid: process.pid,
    workerPid: process.pid,
    writeCapable: !['consult', 'plan', 'review'].includes(options.mode),
    params: {
      model: options.model,
      mode: options.mode,
      cwd: options.cwd,
      approval: options.approval,
      threshold: options.threshold,
      timeoutSeconds: options.timeoutSeconds,
      sandbox: options.sandbox,
      resume: options.resume,
      overrideLimit: options.overrideLimit,
      overrideLane: options.overrideLane,
      allowSensitive: options.allowSensitive,
      background: extra.background === true
    }
  };
}

function launchBackground(originalArgs, options) {
  const shadow = beginDirectShadow(directShadowOptions(options, { background: true }), { prefix: 'delegate-cursor' });
  const id = shadow.id || createJobId();
  fs.mkdirSync(jobsDir(), { recursive: true, mode: 0o700 });
  const stdoutPath = path.join(jobsDir(), `${id}.out.log`);
  const stderrPath = path.join(jobsDir(), `${id}.err.log`);
  const stdout = fs.openSync(stdoutPath, 'a', 0o600);
  const stderr = fs.openSync(stderrPath, 'a', 0o600);
  // The prompt travels via a private file, never through child argv, where any
  // local process could read it from the process table.
  const promptPath = path.join(jobsDir(), `${id}.prompt`);
  fs.writeFileSync(promptPath, options.prompt, { mode: 0o600 });
  const forwarded = stripPromptArgs(originalArgs.filter((value) => value !== '--background'));
  forwarded.push('--prompt-file', promptPath);
  if (shadow.id) forwarded.push('--job-id', id);
  const child = spawn(process.execPath, [fileURLToPath(import.meta.url), ...forwarded], {
    cwd: options.cwd,
    detached: true,
    stdio: ['ignore', stdout, stderr],
    windowsHide: true,
    env: process.env
  });
  fs.closeSync(stdout);
  fs.closeSync(stderr);
  shadow.update((job) => {
    job.pid = child.pid;
    job.workerPid = child.pid;
    job.stdoutPath = stdoutPath;
    job.stderrPath = stderrPath;
  });
  child.unref();
  console.log(JSON.stringify({ jobId: id, status: 'running', command: `delegate-jobs status ${id}` }, null, 2));
}

const originalArgs = process.argv.slice(2);
const options = parseArgs(originalArgs);
if (!providerEnabled('cursor')) fail('Cursor is disabled for this installation');
const limitOverrides = String(process.env.DELEGATE_ALLOW_OVER_LIMIT || '')
  .split(',').map((value) => value.trim()).filter(Boolean);
if (limitOverrides.includes('cursor') || limitOverrides.includes('all')) options.overrideLimit = true;
if (options.help) { usage(); process.exit(0); }
if (!['consult', 'plan', 'review', 'implement', 'verify'].includes(options.mode)) fail(`invalid mode: ${options.mode}`);
if (!['auto', 'force'].includes(options.approval)) fail(`invalid approval: ${options.approval}`);
if (!Number.isFinite(options.threshold)) fail('threshold must be a number');
if (!Number.isFinite(options.timeoutSeconds) || options.timeoutSeconds < 10 || options.timeoutSeconds > 86400) {
  fail('timeout-seconds must be between 10 and 86400');
}
if (options.promptFile) options.prompt = fs.readFileSync(options.promptFile, 'utf8');
if (!options.prompt) fail('a prompt or prompt file is required');
if (!fs.existsSync(options.cwd)) fail(`cwd does not exist: ${options.cwd}`);

const binary = resolveCursorBinary();
if (!binary) fail('neither agent nor cursor-agent is executable');

const state = loadState();
// Same WRONG_LANE rule as the managed broker: GPT models route natively
// through Codex unless the user explicitly asked for Cursor, or Codex is
// disabled or at its avoid band. Resumes continue their existing lane.
if (/^gpt-/i.test(options.model || '') && !options.overrideLane && !options.resume && providerEnabled('codex')) {
  const codexUsage = effectiveUsage(state, 'codex');
  if (!(codexUsage.known && codexUsage.usedPercent >= avoidPercentFor('codex'))) {
    fail(`WRONG_LANE: '${options.model}' routes natively through Codex; use Cursor for GPT models only when the user explicitly asks (pass --override-lane) or Codex is disabled or at its avoid threshold`);
  }
}
const cursorUsage = effectiveUsage(state, 'cursor');
const effectiveThreshold = options.resume ? Math.max(options.threshold, 98) : options.threshold;
if (!options.overrideLimit && cursorUsage.known && cursorUsage.usedPercent >= effectiveThreshold) {
  fail(`Cursor is at ${cursorUsage.usedPercent}% (threshold ${effectiveThreshold}%); route to a fallback or pass --override-limit`, 75);
}

if (options.background && !options.jobId) {
  launchBackground(originalArgs, options);
  process.exit(0);
}

const ids = availableModelIds(binary);
let model;
try { model = resolveCursorModel(options.model, ids); } catch (error) { fail(error.message); }
if (options.sandbox != null && options.sandbox !== 'auto' && options.sandbox !== 'off') {
  fail("--sandbox must be 'auto' or 'off'");
}
const cursorArgs = buildCursorArgs({
  mode: options.mode,
  model,
  cwd: options.cwd,
  approval: options.approval,
  resume: options.resume,
  sandbox: options.sandbox === 'off' ? 'off' : null
});
const prompt = `${securityPreamble(options.allowSensitive)}${options.prompt}`;

if (options.dryRun) {
  console.log(JSON.stringify({
    binary,
    model,
    mode: options.mode,
    approval: options.approval,
    cwd: options.cwd,
    resume: options.resume,
    timeoutSeconds: options.timeoutSeconds,
    promptTransport: 'stdin',
    sensitiveFileGuard: !options.allowSensitive,
    commandArgs: cursorArgs
  }, null, 2));
  process.exit(0);
}

const started = Date.now();
let shadow = options.jobId ? adoptDirectShadow(options.jobId, { prefix: 'delegate-cursor' }) : null;
if (!shadow) shadow = beginDirectShadow(directShadowOptions(options, { model, resolvedModel: model }), { prefix: 'delegate-cursor' });
shadow.update((job) => {
  job.pid = process.pid;
  job.workerPid = process.pid;
  job.model = model;
  job.resolvedModel = model;
  job.phase = 'running';
});
shadow.event('provider.initialized', { transport: 'direct-cli', model });
shadow.event('turn.started', { transport: 'direct-cli', resume: options.resume }, { sessionId: options.resume });

recordEvent(state, {
  provider: 'cursor', model, mode: options.mode, status: 'started',
  promptChars: options.prompt.length, jobId: shadow.id
});
saveState(state);

let activeChild = null;
let stopping = false;
async function stop() {
  if (stopping) return;
  stopping = true;
  if (activeChild) await terminateProcessTree(activeChild);
}
process.once('SIGINT', stop);
process.once('SIGTERM', stop);

const seenProgress = new Set();
const deltas = new DeltaRedactor();
const assistantParts = [];
const activity = shadow.id ? new ActivityTransitionEmitter(shadow.id, {
  emit: (kind, at) => shadow.event('activity', { kind, at })
}) : null;
const ephemeral = activity ? new EphemeralCursorActivity(activity) : null;
const launch = cursorLaunchCommand(binary, cursorArgs, false);
const outcome = await runCursor({
  binary: launch.command,
  args: launch.args,
  cwd: options.cwd,
  prompt,
  timeoutMs: options.timeoutSeconds * 1000,
  onChild: (child) => { activeChild = child; },
  onEvent: (event) => {
    shadow.safe((job) => mapCursorHeadlessEvent(job, event, { deltas, assistantParts, ephemeral }));
  },
  onProgress: (message) => {
    if (!seenProgress.has(message)) {
      seenProgress.add(message);
      console.error(`[delegate-cursor] ${message}`);
    }
  }
});

const session = findValue(outcome.payload, ['session_id', 'sessionId', 'chat_id', 'chatId']);
const inputTokens = findValue(outcome.payload, ['input_tokens', 'inputTokens']);
const outputTokens = findValue(outcome.payload, ['output_tokens', 'outputTokens']);
recordEvent(state, {
  provider: 'cursor', model, mode: options.mode,
  status: outcome.status === 0 ? 'ok' : 'failed',
  exitCode: outcome.exitCode,
  durationMs: Date.now() - started,
  session,
  inputTokens,
  outputTokens,
  jobId: shadow.id,
  timedOut: outcome.timedOut,
  cancelled: outcome.cancelled || stopping
});
if (outcome.status !== 0 && /(?:quota|usage limit|rate limit|allowance)/i.test(outcome.stderr || outcome.error || '')) {
  setWindow(state, 'cursor', 'quota-error', 100, { source: 'quota-error' });
}
saveState(state);

shadow.setSession(session, model);
shadow.event('turn.completed', { status: outcome.status, error: outcome.error }, { sessionId: session });
shadow.safe((job) => recordGitState(job, session, { includeLineCounts: true }));
shadow.complete({
  status: outcome.status === 0 ? 'completed' : outcome.cancelled || stopping ? 'cancelled' : 'failed',
  providerSessionId: session,
  resolvedModel: model,
  result: outcome.payload,
  resultText: typeof outcome.payload?.result === 'string' ? outcome.payload.result : '',
  usage: inputTokens != null || outputTokens != null ? { inputTokens, outputTokens } : null,
  ...(outcome.error ? { error: outcome.error, errorCode: outcome.timedOut ? 'TIMEOUT' : 'PROVIDER_ERROR' } : {})
});
activity?.close();

if (outcome.payload) console.log(JSON.stringify(outcome.payload));
if (outcome.error) console.error(`delegate-cursor: ${outcome.error}`);
process.exitCode = outcome.status;
